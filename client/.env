# ============================================================
# frontend/.env
# Environment variables untuk Vite.
# PENTING: semua variabel HARUS diawali VITE_ agar bisa diakses
# di browser via import.meta.env.VITE_XXX
# File ini JANGAN di-commit ke Git (tambahkan ke .gitignore)
# ============================================================

# URL backend API
VITE_API_URL=http://localhost:5000/api

# Nama aplikasi (opsional, dipakai di meta tags, dll)
VITE_APP_NAME=AMARANTA
